FLASK_ENV=development
FLASK_SECRET_KEY=change-me
GEMINI_API_KEY=your-gemini-api-key

# Local defaults
DATABASE_URL=sqlite:///data/researchgpt.db
UPLOAD_FOLDER=uploads
CHROMA_DB_DIR=data/chromadb
MAX_CONTENT_LENGTH=26214400

# Production provider switches
STORAGE_BACKEND=local
VECTOR_BACKEND=chroma
QUEUE_BACKEND=sync

# PostgreSQL example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# S3-compatible storage, required when STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=

# Pinecone, required when VECTOR_BACKEND=pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# Redis/RQ, required when QUEUE_BACKEND=rq
REDIS_URL=
